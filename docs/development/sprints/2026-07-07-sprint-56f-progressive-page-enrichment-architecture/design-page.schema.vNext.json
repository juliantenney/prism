{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prism.local/schema/design-page-v2.0.0.schema.json",
  "title": "Design Page v2.0.0 (Progressive Enrichment)",
  "description": "Authoritative vNext schema for progressively enriched page artefacts. Supersedes design-page.schema.json (56E). Design Page LLM merge is retired; each workflow stage writes only fields it owns. This schema describes the complete page artefact; per-stage subset validation is an implementation concern.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "title",
    "audience",
    "page_profile",
    "assembly_state",
    "page_synthesis",
    "activities",
    "learning_outcomes",
    "source_artefacts",
    "generation_notes"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "page"
    },
    "schema_version": {
      "type": "string",
      "const": "2.0.0"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "page_profile": {
      "$ref": "#/$defs/PageProfile"
    },
    "assembly_state": {
      "$ref": "#/$defs/AssemblyState"
    },
    "page_synthesis": {
      "$ref": "#/$defs/PageSynthesis"
    },
    "activities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Activity"
      }
    },
    "learning_sequence": {
      "$ref": "#/$defs/LearningSequence"
    },
    "assessment_check": {
      "$ref": "#/$defs/AssessmentCheck"
    },
    "learning_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LearningOutcome"
      }
    },
    "episode_plans": {
      "type": "array",
      "description": "Required when Episode Plan step is in the workflow; omit or empty when EP step is absent (OD-06).",
      "items": {
        "$ref": "#/$defs/EpisodePlanRow"
      }
    },
    "source_artefacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SourceArtefact"
      }
    },
    "constraints_applied": {
      "$ref": "#/$defs/ConstraintsApplied"
    },
    "generation_notes": {
      "$ref": "#/$defs/GenerationNotes"
    }
  },
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "PageProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_type"],
      "properties": {
        "profile_type": {
          "type": "string",
          "enum": ["learner", "facilitator", "assessment"]
        },
        "mode": { "$ref": "#/$defs/NonEmptyString" },
        "level": { "$ref": "#/$defs/NonEmptyString" },
        "delivery_context": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "AssemblyState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enriched_by"],
      "properties": {
        "enriched_by": {
          "type": "array",
          "description": "Append-only list of enrichment stage identifiers.",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "current_stage": { "$ref": "#/$defs/NonEmptyString" },
        "page_shell_id": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "SynthesisText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body"],
      "properties": {
        "body": { "$ref": "#/$defs/NonEmptyString" },
        "format": {
          "type": "string",
          "enum": ["markdown", "plain_text"],
          "default": "markdown"
        },
        "heading": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "KnowledgeConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "definition"],
      "properties": {
        "name": { "$ref": "#/$defs/NonEmptyString" },
        "definition": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "KnowledgeSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "concepts": {
          "type": "array",
          "items": { "$ref": "#/$defs/KnowledgeConcept" }
        },
        "relationships": { "$ref": "#/$defs/NonEmptyString" },
        "use_in_activities": { "$ref": "#/$defs/NonEmptyString" },
        "body": {
          "type": "string",
          "description": "Prose fallback when structured concepts are unavailable (OD-02). When knowledge_model is bound and only body is present, record audit flag prose_only_fallback."
        },
        "prose_only_fallback": {
          "type": "boolean",
          "description": "Set true when KM was bound but knowledge_summary uses prose body only without structured concepts (OD-02 audit flag)."
        }
      },
      "anyOf": [
        { "required": ["concepts"] },
        { "required": ["body"] }
      ]
    },
    "PageSynthesis": {
      "type": "object",
      "additionalProperties": false,
      "description": "Owner: finalise_page. Object is required; all child keys are optional (OD-01). LC/KM must not write directly (OD-09).",
      "properties": {
        "overview": { "$ref": "#/$defs/SynthesisText" },
        "learning_purpose": { "$ref": "#/$defs/SynthesisText" },
        "knowledge_summary": { "$ref": "#/$defs/KnowledgeSummary" },
        "study_tips": { "$ref": "#/$defs/SynthesisText" },
        "support_notes": { "$ref": "#/$defs/SynthesisText" }
      }
    },
    "RequiredMaterial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_id"],
      "properties": {
        "material_id": { "$ref": "#/$defs/NonEmptyString" },
        "type": { "$ref": "#/$defs/NonEmptyString" },
        "material_type": { "$ref": "#/$defs/NonEmptyString" },
        "purpose": { "$ref": "#/$defs/NonEmptyString" },
        "specification": { "$ref": "#/$defs/NonEmptyString" },
        "instructional_function": { "$ref": "#/$defs/NonEmptyString" },
        "obligation_class": { "$ref": "#/$defs/NonEmptyString" },
        "plan_beat_index": { "type": "integer", "minimum": 0 }
      }
    },
    "Material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_id", "material_type", "title", "body"],
      "properties": {
        "material_id": { "$ref": "#/$defs/NonEmptyString" },
        "material_type": {
          "type": "string",
          "minLength": 1,
          "description": "Open vocabulary string (OD-08). Documented types include: text, worked_example, checklist, scenario, prompt_set, template, tables, transfer_prompt, consolidation_summary, reflection_prompt, modelling_note, sample_output, comparison_table, analysis_table."
        },
        "title": { "$ref": "#/$defs/NonEmptyString" },
        "body": { "$ref": "#/$defs/NonEmptyString" },
        "body_format": {
          "type": "string",
          "enum": ["markdown", "html", "plain_text"],
          "default": "markdown"
        }
      }
    },
    "EpisodePlanBeat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["function"],
      "properties": {
        "function": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "EpisodePlanChoreography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archetype", "beats"],
      "properties": {
        "archetype": { "$ref": "#/$defs/NonEmptyString" },
        "beats": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/EpisodePlanBeat" }
        }
      }
    },
    "Activity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity_id",
        "title",
        "learner_task",
        "expected_output",
        "activity_preamble",
        "required_materials",
        "materials"
      ],
      "properties": {
        "activity_id": { "$ref": "#/$defs/NonEmptyString" },
        "title": { "$ref": "#/$defs/NonEmptyString" },
        "learner_task": { "$ref": "#/$defs/NonEmptyString" },
        "expected_output": { "$ref": "#/$defs/NonEmptyString" },
        "activity_preamble": { "$ref": "#/$defs/NonEmptyString" },
        "support_note": { "$ref": "#/$defs/NonEmptyString" },
        "purpose": { "$ref": "#/$defs/NonEmptyString" },
        "duration_minutes": { "type": "number", "minimum": 0 },
        "grouping": { "$ref": "#/$defs/NonEmptyString" },
        "learning_outcome_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "mapped_learning_outcomes": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "required_materials": {
          "type": "array",
          "items": { "$ref": "#/$defs/RequiredMaterial" }
        },
        "materials": {
          "type": "array",
          "description": "Populated by GAM; write-once immutable after GAM stage.",
          "items": { "$ref": "#/$defs/Material" }
        },
        "study_orientation": { "$ref": "#/$defs/NonEmptyString" },
        "intellectual_frame": { "$ref": "#/$defs/NonEmptyString" },
        "intellectual_coherence_bridge": { "$ref": "#/$defs/NonEmptyString" },
        "reasoning_orientation": { "$ref": "#/$defs/NonEmptyString" },
        "self_explanation_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "evidence_use_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "argument_structure_hint": { "$ref": "#/$defs/NonEmptyString" },
        "conceptual_contrast_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "disciplinary_lens": { "$ref": "#/$defs/NonEmptyString" },
        "transfer_or_application_task": { "$ref": "#/$defs/NonEmptyString" },
        "scaffold_hint_sequence": {
          "oneOf": [
            { "$ref": "#/$defs/NonEmptyString" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/NonEmptyString" }
            }
          ]
        },
        "uncertainty_tension_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "prior_knowledge_activation": { "$ref": "#/$defs/NonEmptyString" },
        "misconception_claim": { "$ref": "#/$defs/NonEmptyString" },
        "reconciliation_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "evidence_contrast": { "$ref": "#/$defs/NonEmptyString" },
        "reasoning_revision_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "initial_position_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "revision_trigger": { "$ref": "#/$defs/NonEmptyString" },
        "transformation_activity": { "$ref": "#/$defs/NonEmptyString" },
        "source_to_application_prompt": { "$ref": "#/$defs/NonEmptyString" },
        "episode_plan_id": { "$ref": "#/$defs/NonEmptyString" },
        "episode_plan_source_activity_id": { "$ref": "#/$defs/NonEmptyString" },
        "episode_plan": { "$ref": "#/$defs/EpisodePlanChoreography" }
      },
      "not": {
        "anyOf": [
          { "required": ["orienting_preamble"] },
          { "required": ["activity_framing"] },
          { "required": ["support_notes"] },
          { "required": ["facilitator_moves"] },
          { "required": ["pel_links"] },
          { "required": ["metacognition_checks"] },
          { "required": ["confidence_checks"] },
          { "required": ["transfer_prompts"] },
          { "required": ["consolidation_prompts"] },
          { "required": ["reflection_prompts"] },
          { "required": ["journey_extensions"] }
        ]
      }
    },
    "LearningOutcome": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome_id", "statement"],
          "properties": {
            "outcome_id": { "$ref": "#/$defs/NonEmptyString" },
            "statement": { "$ref": "#/$defs/NonEmptyString" },
            "category": { "$ref": "#/$defs/NonEmptyString" }
          }
        }
      ]
    },
    "LearningSequenceTimelineEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activity_id"],
      "properties": {
        "block_id": { "$ref": "#/$defs/NonEmptyString" },
        "activity_id": { "$ref": "#/$defs/NonEmptyString" },
        "phase_type": { "$ref": "#/$defs/NonEmptyString" },
        "transition_to_next": { "$ref": "#/$defs/NonEmptyString" },
        "start_minute": { "type": "number", "minimum": 0 },
        "duration_minutes": { "type": "number", "minimum": 0 },
        "grouping": { "$ref": "#/$defs/NonEmptyString" },
        "facilitator_actions": { "$ref": "#/$defs/NonEmptyString" },
        "learner_actions": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "LearningSequence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ordered_activity_ids"],
      "properties": {
        "ordered_activity_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "sequence_title": { "$ref": "#/$defs/NonEmptyString" },
        "total_duration_minutes": { "type": "number", "minimum": 0 },
        "is_binding": { "type": "boolean" },
        "notes": { "$ref": "#/$defs/NonEmptyString" },
        "timeline": {
          "type": "array",
          "items": { "$ref": "#/$defs/LearningSequenceTimelineEntry" }
        }
      }
    },
    "AssessmentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "prompt"],
      "properties": {
        "item_id": { "$ref": "#/$defs/NonEmptyString" },
        "prompt": { "$ref": "#/$defs/NonEmptyString" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "expected_evidence": { "$ref": "#/$defs/NonEmptyString" },
        "success_criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        }
      }
    },
    "AssessmentCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/AssessmentItem" }
        },
        "feedback_guidance": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        }
      }
    },
    "EpisodePlanRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activity_id", "episode_plan"],
      "properties": {
        "activity_id": { "$ref": "#/$defs/NonEmptyString" },
        "episode_plan_id": { "$ref": "#/$defs/NonEmptyString" },
        "mapped_learning_outcome_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "episode_plan": { "$ref": "#/$defs/EpisodePlanChoreography" }
      }
    },
    "SourceArtefact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artefact_type", "role"],
      "properties": {
        "artefact_type": { "$ref": "#/$defs/NonEmptyString" },
        "artefact_id": { "$ref": "#/$defs/NonEmptyString" },
        "source_label": { "$ref": "#/$defs/NonEmptyString" },
        "role": { "$ref": "#/$defs/NonEmptyString" }
      },
      "oneOf": [
        { "required": ["artefact_id"] },
        { "required": ["source_label"] }
      ]
    },
    "ConstraintsApplied": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "notes": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "ValidationReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity_coverage",
        "material_coverage",
        "episode_plan_attachment",
        "self_containment",
        "schema_compliance",
        "known_issues"
      ],
      "properties": {
        "activity_coverage": { "$ref": "#/$defs/NonEmptyString" },
        "material_coverage": { "$ref": "#/$defs/NonEmptyString" },
        "episode_plan_attachment": { "$ref": "#/$defs/NonEmptyString" },
        "self_containment": { "$ref": "#/$defs/NonEmptyString" },
        "schema_compliance": { "$ref": "#/$defs/NonEmptyString" },
        "known_issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        }
      }
    },
    "GenerationNotes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation"],
      "properties": {
        "validation": {
          "$ref": "#/$defs/ValidationReport"
        },
        "limitations": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "activities_omitted": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "notes": { "$ref": "#/$defs/NonEmptyString" }
      }
    }
  }
}
