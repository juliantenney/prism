{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prism.local/schema/design-page-v2.schema.json",
  "title": "Design Page v2 Schema",
  "description": "Authoritative v2 schema for Design Page assembly outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "title",
    "audience",
    "page_profile",
    "sections",
    "learning_outcomes",
    "learning_sequence",
    "episode_plans",
    "source_artefacts",
    "generation_notes"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "page"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "page_profile": {
      "$ref": "#/$defs/PageProfile"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Section"
      },
      "allOf": [
        { "contains": { "type": "object", "properties": { "section_id": { "const": "overview" } }, "required": ["section_id"] } },
        { "contains": { "type": "object", "properties": { "section_id": { "const": "learning_purpose" } }, "required": ["section_id"] } },
        { "contains": { "type": "object", "properties": { "section_id": { "const": "knowledge_summary" } }, "required": ["section_id"] } },
        { "contains": { "type": "object", "properties": { "section_id": { "const": "learning_activities" } }, "required": ["section_id"] } },
        { "contains": { "type": "object", "properties": { "section_id": { "const": "assessment_check" } }, "required": ["section_id"] } },
        { "contains": { "type": "object", "properties": { "section_id": { "const": "support_notes" } }, "required": ["section_id"] } }
      ]
    },
    "learning_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LearningOutcome"
      }
    },
    "learning_sequence": {
      "$ref": "#/$defs/LearningSequence"
    },
    "episode_plans": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EpisodePlan"
      }
    },
    "source_artefacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SourceArtefact"
      }
    },
    "constraints_applied": {
      "$ref": "#/$defs/ConstraintsApplied"
    },
    "generation_notes": {
      "$ref": "#/$defs/GenerationNotes"
    }
  },
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "PageProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_type"],
      "properties": {
        "profile_type": { "$ref": "#/$defs/NonEmptyString" },
        "mode": { "$ref": "#/$defs/NonEmptyString" },
        "level": { "$ref": "#/$defs/NonEmptyString" },
        "delivery_context": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "LearningOutcome": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome_id", "statement"],
          "properties": {
            "outcome_id": { "$ref": "#/$defs/NonEmptyString" },
            "statement": { "$ref": "#/$defs/NonEmptyString" },
            "category": { "$ref": "#/$defs/NonEmptyString" }
          }
        }
      ]
    },
    "LearningSequence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ordered_activity_ids"],
      "properties": {
        "ordered_activity_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "is_binding": { "type": "boolean" },
        "notes": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "Section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "heading", "content"],
      "properties": {
        "section_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "heading": { "$ref": "#/$defs/NonEmptyString" },
        "content": {}
      },
      "allOf": [
        {
          "if": { "properties": { "section_id": { "const": "overview" } }, "required": ["section_id"] },
          "then": { "properties": { "content": { "$ref": "#/$defs/TextOrBlocks" } } }
        },
        {
          "if": { "properties": { "section_id": { "const": "learning_purpose" } }, "required": ["section_id"] },
          "then": { "properties": { "content": { "$ref": "#/$defs/TextOrBlocks" } } }
        },
        {
          "if": { "properties": { "section_id": { "const": "knowledge_summary" } }, "required": ["section_id"] },
          "then": { "properties": { "content": { "$ref": "#/$defs/TextOrBlocks" } } }
        },
        {
          "if": { "properties": { "section_id": { "const": "learning_activities" } }, "required": ["section_id"] },
          "then": {
            "properties": {
              "content": {
                "type": "array",
                "items": { "$ref": "#/$defs/Activity" }
              }
            }
          }
        },
        {
          "if": { "properties": { "section_id": { "const": "assessment_check" } }, "required": ["section_id"] },
          "then": {
            "properties": {
              "content": {
                "$ref": "#/$defs/AssessmentCheck"
              }
            }
          }
        },
        {
          "if": { "properties": { "section_id": { "const": "support_notes" } }, "required": ["section_id"] },
          "then": { "properties": { "content": { "$ref": "#/$defs/TextOrBlocks" } } }
        },
        {
          "if": { "properties": { "section_id": { "const": "metadata" } }, "required": ["section_id"] },
          "then": {
            "properties": {
              "content": {
                "$ref": "#/$defs/LegacyMetadataContent"
              }
            }
          }
        }
      ]
    },
    "TextOrBlocks": {
      "oneOf": [
        { "$ref": "#/$defs/NonEmptyString" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["blocks"],
          "properties": {
            "blocks": {
              "type": "array",
              "items": { "$ref": "#/$defs/NonEmptyString" }
            }
          }
        }
      ]
    },
    "Activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activity_id", "title", "materials"],
      "properties": {
        "activity_id": { "$ref": "#/$defs/NonEmptyString" },
        "title": { "$ref": "#/$defs/NonEmptyString" },
        "learning_outcome_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "learner_task": { "$ref": "#/$defs/NonEmptyString" },
        "expected_output": { "$ref": "#/$defs/NonEmptyString" },
        "materials": {
          "type": "array",
          "items": { "$ref": "#/$defs/Material" }
        },
        "episode_plan_id": { "$ref": "#/$defs/NonEmptyString" },
        "episode_plan_source_activity_id": { "$ref": "#/$defs/NonEmptyString" },
        "pel_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "reflection_prompts": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "metacognition_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "confidence_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "transfer_prompts": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "consolidation_prompts": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "evidence_of_learning": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "feedback_guidance": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "success_criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "journey_extensions": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        }
      }
    },
    "Material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_id", "material_type", "title", "body"],
      "properties": {
        "material_id": { "$ref": "#/$defs/NonEmptyString" },
        "material_type": { "$ref": "#/$defs/NonEmptyString" },
        "title": { "$ref": "#/$defs/NonEmptyString" },
        "body": { "$ref": "#/$defs/NonEmptyString" },
        "body_format": {
          "type": "string",
          "enum": ["markdown", "html", "plain_text"]
        }
      }
    },
    "AssessmentCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/AssessmentItem" }
        },
        "feedback_guidance": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        }
      }
    },
    "AssessmentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "prompt"],
      "properties": {
        "item_id": { "$ref": "#/$defs/NonEmptyString" },
        "prompt": { "$ref": "#/$defs/NonEmptyString" },
        "expected_evidence": { "$ref": "#/$defs/NonEmptyString" },
        "success_criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        }
      }
    },
    "EpisodePlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["episode_plan_id", "activity_id", "body"],
      "properties": {
        "episode_plan_id": { "$ref": "#/$defs/NonEmptyString" },
        "activity_id": { "$ref": "#/$defs/NonEmptyString" },
        "body": { "$ref": "#/$defs/NonEmptyString" },
        "timing_metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "estimated_minutes": {
              "type": "number",
              "minimum": 0
            },
            "sequence_index": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "choreography_metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "phase": { "$ref": "#/$defs/NonEmptyString" },
            "beat_function": { "$ref": "#/$defs/NonEmptyString" },
            "interaction_mode": { "$ref": "#/$defs/NonEmptyString" }
          }
        }
      }
    },
    "SourceArtefact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artefact_type", "role"],
      "properties": {
        "artefact_type": { "$ref": "#/$defs/NonEmptyString" },
        "artefact_id": { "$ref": "#/$defs/NonEmptyString" },
        "source_label": { "$ref": "#/$defs/NonEmptyString" },
        "role": { "$ref": "#/$defs/NonEmptyString" }
      },
      "oneOf": [
        { "required": ["artefact_id"] },
        { "required": ["source_label"] }
      ]
    },
    "ConstraintsApplied": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "notes": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "GenerationNotes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation"],
      "properties": {
        "validation": {
          "$ref": "#/$defs/ValidationReport"
        },
        "limitations": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "activities_omitted": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "notes": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "ValidationReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity_coverage",
        "material_coverage",
        "episode_plan_attachment",
        "self_containment",
        "schema_compliance",
        "known_issues"
      ],
      "properties": {
        "activity_coverage": { "$ref": "#/$defs/NonEmptyString" },
        "material_coverage": { "$ref": "#/$defs/NonEmptyString" },
        "episode_plan_attachment": { "$ref": "#/$defs/NonEmptyString" },
        "self_containment": { "$ref": "#/$defs/NonEmptyString" },
        "schema_compliance": { "$ref": "#/$defs/NonEmptyString" },
        "known_issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/NonEmptyString" }
        }
      }
    },
    "LegacyMetadataContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "value"],
            "properties": {
              "key": { "$ref": "#/$defs/NonEmptyString" },
              "value": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "boolean" }
                ]
              }
            }
          }
        }
      }
    }
  }
}
