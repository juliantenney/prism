      "activities": [
        {
          "id": "A1",
          "learner_task": "1. Read the introductory explanation.\n2. Study the worked example showing how an educational issue can be examined using evidence.\n3. Review the sample response.\n4. Create your own definition of educational psychology.\n5. Identify two ways it can inform practice.\n6. Complete the self-check checklist and revise your response if required.",
          "expected_output": "Produce a concise explanation that accurately defines educational psychology and identifies at least two evidence-informed applications. Strong responses connect research evidence to educational decision-making and use terminology consistently.",
          "materialCount": 0,
          "materials": [],
          "instructionWords": 80
        },
        {
          "id": "A2",
          "learner_task": "1. Read the comparison overview.\n2. Study the worked analytic example.\n3. Review the classroom scenarios.\n4. Complete the comparison table.\n5. Analyse which theory is most visible in each scenario and justify your judgement.\n6. Use the checklist to review your analysis.",
          "expected_output": "Complete a comparative analysis that accurately distinguishes behaviourism, cognitivism and constructivism. High-quality responses justify classifications using features of each theory and explain reasoning rather than simply naming theories.",
          "materialCount": 0,
          "materials": [],
          "instructionWords": 71
        },
        {
          "id": "A3",
          "learner_task": "1. Read the explanation of memory systems.\n2. Review the unordered process cards.\n3. Sequence the stages of information processing.\n4. Explain the role of retrieval practice and spaced practice.\n5. Check your sequence and explanations against the verification criteria.",
          "expected_output": "Produce a correctly sequenced explanation of the learning process and a clear account of how retrieval and spaced practice support long-term retention. Explanations should accurately connect cognitive processes.",
          "materialCount": 0,
          "materials": [],
          "instructionWords": 68
        },
        {
          "id": "A4",
          "learner_task": "1. Read the motivation overview.\n2. Review the learner cases.\n3. Compare examples of intrinsic and extrinsic motivation.\n4. Analyse the role of self-efficacy in each case.\n5. Complete the analysis table and self-check.",
          "expected_output": "Generate a justified comparison of intrinsic and extrinsic motivation and explain how self-efficacy influences engagement. Strong responses use evidence from cases and identify relationships between motivation and persistence.",
          "materialCount": 0,
          "materials": [],
          "instructionWords": 62
        },
        {
          "id": "A5",
          "learner_task": "1. Review the classroom scenario.\n2. Study the modelled application example.\n3. Complete the planning template.\n4. Recommend inclusive and evidence-informed actions.\n5. Write a short synthesis explaining your reasoning.\n6. Complete the verification checklist.\n7. Read the consolidation summary and identify three key takeaways.",
          "expected_output": "Produce a short evidence-informed action plan that identifies learner needs, proposes inclusive support strategies and justifies decisions using concepts from educational psychology. High-quality responses integrate multiple concepts rather than discussing them separately.",
          "materialCount": 0,
          "materials": [],
          "instructionWords": 77
        }
      ]
    },
